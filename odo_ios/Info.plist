<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- App Store: avoids export compliance question on every submission -->
	<key>ITSAppUsesNonExemptEncryption</key>
	<false/>
	<!-- Override bundle name so ASWebAuthenticationSession shows "ODO" -->
	<key>CFBundleName</key>
	<string>ODO</string>
	<!-- Google Sign-In SDK client ID (replace with your iOS client ID from Google Cloud Console) -->
	<key>GIDClientID</key>
	<string>867416683011-fcsejbq9k5l85ue47nivov02pelhlah6.apps.googleusercontent.com</string>
	<!-- URL schemes for OAuth callbacks -->
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>odo</string>
			</array>
		</dict>
		<dict>
			<!-- Reversed client ID for Google Sign-In (replace with your actual reversed client ID) -->
			<key>CFBundleURLSchemes</key>
			<array>
				<string>com.googleusercontent.apps.867416683011-fcsejbq9k5l85ue47nivov02pelhlah6</string>
			</array>
		</dict>
	</array>
	<!-- Privacy usage descriptions required by iOS for media access -->
	<key>NSCameraUsageDescription</key>
	<string>ODO needs camera access to let you take a photo for upload.</string>
	<key>NSPhotoLibraryUsageDescription</key>
	<string>ODO needs photo library access to let you choose a photo for upload.</string>
	<key>NSMicrophoneUsageDescription</key>
	<string>ODO needs microphone access when recording video for upload.</string>

	<key>UIApplicationSceneManifest</key>
	<dict>
		<key>UIApplicationSupportsMultipleScenes</key>
		<false/>
		<key>UISceneConfigurations</key>
		<dict>
			<key>UIWindowSceneSessionRoleApplication</key>
			<array>
				<dict>
					<key>UISceneConfigurationName</key>
					<string>Default Configuration</string>
					<key>UISceneDelegateClassName</key>
					<string>$(PRODUCT_MODULE_NAME).SceneDelegate</string>
					<key>UISceneStoryboardFile</key>
					<string>Main</string>
				</dict>
			</array>
		</dict>
	</dict>
</dict>
</plist>
